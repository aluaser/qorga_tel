# =========================
# Backend environment config
# =========================

# Required: MongoDB connection string
MONGODB_URI=

# Required in production: set a strong random secret
# (dev fallback exists, but should not be used beyond local testing)
JWT_ACCESS_SECRET=

# Optional: backend port
PORT=4000

# Optional: JWT access token TTL (examples: 15m, 1h, 7d)
ACCESS_TTL=15m

# Optional: comma-separated CORS origins
# Add your Flutter/web origins here.
CLIENT_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Optional: force public base URL for generated file links
# Example for phone testing on same Wi-Fi:
# PUBLIC_BASE_URL=http://192.168.1.10:4000
PUBLIC_BASE_URL=

# Optional: database name override
MONGODB_DB_NAME=qorga

# Optional: fallback Mongo URIs
MONGODB_URI_FALLBACK=
MONGODB_URI_LOCAL=

# Optional: environment mode
NODE_ENV=development

# Optional: SMTP email (forgot password + mood alerts)
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: NewsAPI integration for /content/articles
NEWS_API_KEY=

# Optional: Gemini AI chat integration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: default psychologist bootstrap for chat
DEFAULT_PSYCHOLOGIST_EMAIL=
DEFAULT_PSYCHOLOGIST_GREETING=

# Optional: recipient for SMTP test script (backend npm run email:test)
TEST_EMAIL_TO=
